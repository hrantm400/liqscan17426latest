# /etc/liquidityscan-backup.env — secrets for scripts/backup-db.sh (PR 3.4).
#
# Real file lives at /etc/liquidityscan-backup.env (chmod 600, root-owned)
# and is NOT committed. This example is only for install documentation.
#
# See liquidityscan-web/backend/docs/BACKUPS.md for end-to-end setup.

# ---- Postgres ----
PGHOST=localhost
PGUSER=liquidityscan
PGPASSWORD=REPLACE_ME
PGDATABASE=liquidityscan_db

# ---- Paths ----
BACKUP_DIR=/var/backups/liquidityscan
# Passphrase lives in a SEPARATE file (chmod 600) so it never leaks into
# `ps aux` / `/proc/<pid>/environ`.
GPG_PASSPHRASE_FILE=/etc/liquidityscan-backup.passphrase

# ---- Dead-man switch (healthchecks.io) ----
# Create a check with schedule "30 4 * * *" UTC and grace 60 min.
HEALTHCHECKS_PING_URL=https://hc-ping.com/REPLACE_ME_UUID

# ---- Off-box mirror (Backblaze B2) ----
# rclone remote name MUST be `b2` — configure once with `rclone config`
# and put the account ID + application key in ~root/.config/rclone/rclone.conf
# (chmod 600). This script only references the bucket name.
B2_BUCKET=liquidityscan-backups

# ---- Telegram alerts ----
# Reuse the same bot token as the backend (liquidityscan-web/backend/.env).
# Admin chat_id is your personal chat with the bot or an admin group.
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_ADMIN_CHAT_ID=REPLACE_ME

# Daily "backup OK" message on every successful run.
# Enabled by default so silence = immediately noticed in the morning.
# Set to 0 to disable if it becomes noisy.
TELEGRAM_NOTIFY_SUCCESS=1
