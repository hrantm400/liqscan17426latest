# /etc/cron.d/liquidityscan-backup — PR 3.4
#
# Daily Postgres backup at 04:30 UTC (08:30 local +04).
# healthchecks.io owns dead-man alerting; no MAILTO (box has no MTA).
# Script handles its own Telegram + healthchecks pings via trap ERR.

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

30 4 * * * root /var/www/liquidityscan-app/scripts/backup-db.sh >> /var/backups/liquidityscan/backup.log 2>&1
