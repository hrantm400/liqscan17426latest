# =============================================================================
# Copy to .env and fill with real values. Never commit .env to Git.
# Local: use localhost and port 3000. Production/Server: use domain and PORT=3002.
# =============================================================================

# Database (PostgreSQL). On server: use real user/password and liquidityscan_db.
DATABASE_URL="postgresql://postgres:password@localhost:5432/liquidityscan_db?schema=public"

# JWT (generate strong random strings for production)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Admin: comma-separated emails with admin access
ADMIN_EMAILS=admin@example.com,superadmin@example.com

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Local: http://localhost:3000/api/auth/google/callback
# Production: https://liquidityscan.io/api/auth/google/callback (set in Google Console too)
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Server
# Local: PORT=3000. On server (173.249.3.156): PORT=3002 (3000/3001 used by superengulfing)
PORT=3000
# Bind address for the HTTP server (default 127.0.0.1). Use 0.0.0.0 only for remote dev access.
# LISTEN_HOST=0.0.0.0
NODE_ENV=development
# Local: http://localhost:5173. Production: https://liquidityscan.io
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# API hardening (optional)
# Set to true to enable Helmet Content-Security-Policy on the JSON API (default: off; SPA static assets use their own headers).
HELMET_CSP=false

# CoinMarketCap proxy for GET /api/cmc/ranks (optional)
CMCAPIKEY=

# Future: httpOnly Secure cookies for tokens, refresh rotation, and stricter CSP on the static frontend are separate hardening steps.

# Live bias: max distinct ICT_BIAS symbols per timeframe for GET /signals/live-bias (reduces memory/502 when DB lists thousands of pairs).
LIVE_BIAS_MAX_SYMBOLS=450

# Signals webhook (for Python dev / Grno). POST /api/signals/webhook, header: x-webhook-secret
# Generate a long random string; give the same value to the developer as "Preferred secret key".
SIGNALS_WEBHOOK_SECRET=your_webhook_secret_change_in_production

# Market scanner: set to false during dev to stop hourly + POST /signals/scan (saves Binance API weight).
# Or run: npm run scanner:env-off  (then restart API). Default when unset: enabled.
# MARKET_SCANNER_ENABLED=true

# Binance Futures API Keys (for rate limiting - read-only keys, no trading permissions needed)
# Generate at https://www.binance.com/en/my/settings/api-management
# Enable only "Reading" permission. Optionally enable "Futures" for futures data.
# Two keys allow doubling the rate limit (each key has separate 2400 req/min quota).
# If you only have one key, set both to the same value or leave BINANCE_API_KEY_2 empty.
BINANCE_API_KEY_1=your-first-binance-api-key
BINANCE_API_KEY_2=your-second-binance-api-key

# Observability (PR 3.2). Leave SENTRY_DSN empty to disable Sentry;
# pino-http still emits single-line JSON logs with request IDs.
# sampleRate=1.0 captures every error (tighten if quota pressure appears).
# LOG_LEVEL: fatal | error | warn | info | debug | trace. Use "debug" in dev.
SENTRY_DSN=
SENTRY_SAMPLE_RATE=1.0
LOG_LEVEL=info
