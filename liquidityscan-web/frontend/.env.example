# Copy to .env and fill in values for your environment.
# Local dev: http://localhost:4000/api + ws://localhost:4000/api
# Production: https://liquidityscan.io/api + wss://liquidityscan.io/api
VITE_API_URL=http://localhost:4000/api
VITE_WS_URL=ws://localhost:4000/api

# Google OAuth client ID (public; safe to embed in the SPA bundle).
VITE_GOOGLE_CLIENT_ID=

# Observability (PR 3.2). Leave VITE_SENTRY_DSN empty to disable; the
# ErrorBoundary Sentry.captureException call becomes a silent no-op.
# sampleRate=1.0 captures every error (tighten if quota pressure appears).
VITE_SENTRY_DSN=
VITE_SENTRY_SAMPLE_RATE=1.0
