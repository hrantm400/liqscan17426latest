    ): Promise<Record<string, { bias: string; prevHigh: number; prevLow: number; direction: string }>> {
        const cached = this.liveBiasCache.get(timeframe);
        if (cached && Date.now() - cached.timestamp < ScannerService.BIAS_CACHE_TTL_MS) {
