```typescript
private async checkCrtLifecycle(): Promise<void> {
    const signals = await (this.prisma as any).superEngulfingSignal.findMany({
        where: {
            strategyType: 'CRT',
            lifecycleStatus: { in: ['PENDING', 'ACTIVE'] },
        },
    });
    if (signals.length === 0) return;

    const now = Date.now();
    let strong = 0, weak = 0, failed = 0;

    for (const signal of signals) {
        try {
            const tfMs = TF_MS[signal.timeframe] || TF_MS['4h'];
            const detectedAt = new Date(signal.detectedAt).getTime();
            const candlesSince = Math.floor((now - detectedAt) / tfMs);

            // Not even 1 candle has closed yet — skip
            if (candlesSince < 1) continue;

            // Fetch last 3 closed candles for this symbol/timeframe
            const klines = await this.candlesService.getKlines(signal.symbol, signal.timeframe, 4);
            const closed = klines.slice(0, -1); // remove forming candle
            if (closed.length < 2) continue;

            // Find the first candle that closed AFTER detection
            const firstCandle = closed.find(c => c.openTime > detectedAt);
            if (!firstCandle) continue;

            const entry = Number(signal.price);
            const prevHigh = signal.metadata?.prev_high ?? 0;
            const prevLow = signal.metadata?.prev_low ?? 0;
            const isBuy = signal.signalType === 'BUY';

            let result: 'STRONG' | 'WEAK' | 'FAILED' | null = null;

            if (isBuy) {
                if (firstCandle.close > prevHigh) result = 'STRONG';
                else if (firstCandle.close > entry) result = 'WEAK';
                else if (firstCandle.close < entry) result = 'FAILED';
            } else {
                if (firstCandle.close < prevLow) result = 'STRONG';
                else if (firstCandle.close < entry) result = 'WEAK';
                else if (firstCandle.close > entry) result = 'FAILED';
            }

            // Candle 2 check — if candle 1 was inconclusive and 2 candles have passed
            if (result === null && candlesSince >= 2) {
                const secondCandle = closed.find(c => c.openTime > detectedAt + tfMs);
                if (secondCandle) {
                    if (isBuy) {
                        if (secondCandle.close > prevHigh) result = 'STRONG';
                        else if (secondCandle.close > entry) result = 'WEAK';
                        else result = 'FAILED';
                    } else {
                        if (secondCandle.close < prevLow) result = 'STRONG';
                        else if (secondCandle.close < entry) result = 'WEAK';
                        else result = 'FAILED';
                    }
                }
            }

            // Still no result and max 2 candles passed — force FAILED
            if (result === null && candlesSince >= 2) result = 'FAILED';

            if (result === null) continue; // Not ready yet

            // Close the signal
            const signalResult = result === 'FAILED' ? SignalResult.LOSS : SignalResult.WIN;
            await this.stateService.transitionSignal(signal.id, SignalStatus.COMPLETED, {
                result: signalResult,
                closedPrice: Number(signal.price),
                pnlPercent: 0,
            });

            await (this.prisma as any).superEngulfingSignal.update({
                where: { id: signal.id },
                data: {
                    se_close_reason: result,
                    closedAt: new Date(),
                },
            });

            if (result === 'STRONG') strong++;
            else if (result === 'WEAK') weak++;
            else failed++;

        } catch (err) {
            this.logger.error(`CRT lifecycle error for ${signal.id}: ${err}`);
        }
    }

    if (strong + weak + failed > 0) {
        this.logger.log(`CRT lifecycle: ${strong} STRONG, ${weak} WEAK, ${failed} FAILED.`);
    }
}
```


