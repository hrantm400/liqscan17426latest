# import type { CandleData, CRTSignal } from './candle-types';

/**

* Detect CRT (Candle Range Theory) — institutional liquidity grabs.
* Wick sweeps prev candle's high/low, but body closes back inside range.
* Only returns signal for the most recent closed candle pair.
*/
export function detectCRT(candles: CandleData[]): CRTSignal | null {
if (candles.length < 2) return null;

const i = candles.length - 1;
const curr = candles[i];
const prev = candles[i - 1];

const prevHigh = prev.high;
const prevLow = prev.low;
const prevBody = Math.abs(prev.close - prev.open);
const currBody = Math.abs(curr.close - curr.open);

const bullWickBreak = curr.low < prevLow;
const bullBodyInside = curr.open > prevLow \&\& curr.close > prevLow \&\&
curr.open < prevHigh \&\& curr.close < prevHigh;
const bullCRT = bullWickBreak \&\& bullBodyInside \&\& prevBody > currBody;

const bearWickBreak = curr.high > prevHigh;
const bearBodyInside = curr.open < prevHigh \&\& curr.close < prevHigh \&\&
curr.open > prevLow \&\& curr.close > prevLow;
const bearCRT = bearWickBreak \&\& bearBodyInside \&\& prevBody > currBody;

if (bullCRT \&\& bearCRT) return null;

if (bullCRT) {
return {
direction: 'BUY',
barIndex: i,
time: curr.openTime,
price: curr.close,
sweptLevel: prevLow,
prevHigh,
prevLow,
sweepExtreme: curr.low,
};
}

if (bearCRT) {
return {
direction: 'SELL',
barIndex: i,
time: curr.openTime,
price: curr.close,
sweptLevel: prevHigh,
prevHigh,
prevLow,
sweepExtreme: curr.high,
};
}

return null;
}

CRT in your code is a **2-candle wick sweep pattern** that looks for an institutional-style liquidity grab and return into the prior range.[^44_1]

## Core idea

- Look at the **last two closed candles only**: previous (`prev`) and current (`curr`).[^44_1]
- A valid CRT requires:
    - The current wick sweeps beyond the previous candle’s high or low.
    - The current **body** closes back inside the previous candle’s range.
    - The previous candle’s body is **larger** than the current candle’s body (current is a small reaction candle).[^44_1]

***

## Step-by-step logic

### 1) Basic measurements

```ts
const i = candles.length - 1;
const curr = candles[i];
const prev = candles[i - 1];

const prevHigh = prev.high;
const prevLow = prev.low;
const prevBody = Math.abs(prev.close - prev.open);
const currBody = Math.abs(curr.close - curr.open);
```

- `prevHigh` / `prevLow`: the range to be swept.
- `prevBody` vs `currBody`: ensures current candle is a **smaller** reaction candle.[^44_1]


### 2) Bullish CRT (sweep low, close back inside)

```ts
const bullWickBreak = curr.low < prevLow;
const bullBodyInside =
    curr.open > prevLow && curr.close > prevLow &&
    curr.open < prevHigh && curr.close < prevHigh;

const bullCRT = bullWickBreak && bullBodyInside && prevBody > currBody;
```

- **Wick break:** current low goes below the previous low → liquidity grab below range.[^44_1]
- **Body inside:** both open and close are *inside* the previous candle’s high–low range (above `prevLow`, below `prevHigh`).[^44_1]
- **Body condition:** previous body bigger than current body (`prevBody > currBody`).[^44_1]

If `bullCRT` is true, it returns:[^44_1]

```ts
{
  direction: 'BUY',
  barIndex: i,
  time: curr.openTime,
  price: curr.close,
  sweptLevel: prevLow,
  prevHigh,
  prevLow,
  sweepExtreme: curr.low,
}
```

So:

- Entry is at **current close**.
- `sweptLevel` = previous low (the level where liquidity was grabbed).
- `sweepExtreme` = current low (deepest point of the sweep).[^44_1]


### 3) Bearish CRT (sweep high, close back inside)

```ts
const bearWickBreak = curr.high > prevHigh;
const bearBodyInside =
    curr.open < prevHigh && curr.close < prevHigh &&
    curr.open > prevLow && curr.close > prevLow;

const bearCRT = bearWickBreak && bearBodyInside && prevBody > currBody;
```

- **Wick break:** current high goes above the previous high → sweep above the range.[^44_1]
- **Body inside:** open and close both back inside the previous high–low range.[^44_1]
- **Body condition:** previous body > current body.[^44_1]

If `bearCRT` is true, it returns:[^44_1]

```ts
{
  direction: 'SELL',
  barIndex: i,
  time: curr.openTime,
  price: curr.close,
  sweptLevel: prevHigh,
  prevHigh,
  prevLow,
  sweepExtreme: curr.high,
}
```

So:

- Entry at current close.
- `sweptLevel` = previous high (liquidity level).
- `sweepExtreme` = current high (top of sweep).[^44_1]


### 4) Conflict and “no signal”

```ts
if (bullCRT && bearCRT) return null;
```

- If, for some reason, conditions match both (pathological case), it returns **no signal**.[^44_1]
- If neither pattern matches, returns `null`.[^44_1]

***

## How scanner uses this

From `CrtScanner`:[^44_1]

- Works only on **closed candles** (last one removed).
- Calls `detectCRT` and, if a signal exists, saves it via `saveScannerSignal` with metadata: `crt_direction`, `swept_level`, `prev_high`, `prev_low`, `sweep_extreme`.[^44_1]
- `saveScannerSignal` then:
    - Inserts the CRT signal with `PENDING`/`PENDING`.
    - Calls `archiveOldSignals('CRT', symbol, timeframe)` so only the **latest CRT** for that pair/timeframe stays live, older ones become archived/expired.[^44_1]

