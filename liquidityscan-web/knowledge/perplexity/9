import type { CandleData } from './candle-types';

export interface ThreeCTSignal {
    direction: 'BUY' | 'SELL';
    barIndex: number;
    time: number;
    price: number;       // C0 close — entry
    c1Top: number;       // top of middle candle
    c1Bot: number;       // bottom of middle candle
    c2Open: number;
    c2Close: number;
    c1Open: number;
    c1Close: number;
}

export function detect3CT(
    candles: CandleData[],
    useBodyOnly = false,
): ThreeCTSignal | null {
    if (candles.length < 3) return null;

    const i  = candles.length - 1;
    const c0 = candles[i];
    const c1 = candles[i - 1];
    const c2 = candles[i - 2];

    const isBull = (c: CandleData) => c.close > c.open;
    const isBear = (c: CandleData) => c.close < c.open;
    const cTop   = (c: CandleData) => useBodyOnly ? Math.max(c.open, c.close) : c.high;
    const cBot   = (c: CandleData) => useBodyOnly ? Math.min(c.open, c.close) : c.low;

    const bullPattern =
        isBull(c2) &&
        isBear(c1) &&
