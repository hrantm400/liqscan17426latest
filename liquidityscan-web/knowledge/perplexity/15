import { Injectable } from '@nestjs/common';
import { CandlesService } from '../../candles/candles.service';
import type { RSIDivergenceConfig } from '../indicators';
import { detectRSIDivergence } from '../indicators';
import { getScannerCandles } from '../scanner-candles.helper';
import { SignalsService } from '../signals.service';


const RSI_KLINE_LIMIT = 500;


@Injectable()
export class RsiDivergenceScanner {
    constructor(
        private readonly candlesService: CandlesService,
        private readonly signalsService: SignalsService,
    ) {}


    async scan(symbol: string, timeframe: string, config: RSIDivergenceConfig = {}): Promise<number> {
        const candles = await getScannerCandles(this.candlesService, symbol, timeframe, RSI_KLINE_LIMIT);
        const closedCandles = candles.slice(0, -1);
        if (closedCandles.length < 30) return 0;


        const merged: RSIDivergenceConfig = { ...config };
        const signals = detectRSIDivergence(closedCandles, merged);


        const lbR = merged.lbR ?? 1;
        const latestPivotIndex = closedCandles.length - 1 - lbR;


        const inputs: Array<{
            id: string;
            strategyType: 'RSI_DIVERGENCE';
            symbol: string;
            timeframe: string;
            signalType: string;
            price: number;
            detectedAt: string;
            lifecycleStatus: string;
            status: string;
            metadata: Record<string, unknown>;
        }> = [];


        for (const sig of signals) {
            if (sig.barIndex >= latestPivotIndex) {
                const signalType = sig.type.includes('bullish') ? 'BUY' : 'SELL';
                const id = `RSI_DIVERGENCE-${symbol}-${timeframe}-${sig.time}`;


                inputs.push({
                    id,
                    strategyType: 'RSI_DIVERGENCE',
                    symbol,
                    timeframe,
                    signalType,
                    price: sig.price,
                    detectedAt: new Date(sig.time).toISOString(),
                    lifecycleStatus: 'PENDING',
                    status: 'PENDING',
                    metadata: {
                        divergenceType: sig.type,
                        rsiValue: sig.rsiValue,
                        pivotBarIndex: sig.barIndex,
                        pivotPrice: sig.price,
                        pivotTime: closedCandles[sig.barIndex]?.openTime,
                        prevPivotBarIndex: sig.prevBarIndex,
                        prevPivotPrice: sig.prevPrice,
                        prevPivotRsiValue: sig.prevRsiValue,
                        prevPivotTime: closedCandles[sig.prevBarIndex]?.openTime,
                    },
                });
            }
        }


        let added = 0;
        if (inputs.length > 0) {
            added = await this.signalsService.addSignals(inputs);
        }


        const currentIds = inputs.map((i) => i.id);
        this.signalsService.closeStaleRsiSignals(symbol, timeframe, currentIds).catch(() => {});


        return added;
    }
}

