```typescript
private async check3OBLifecycle(): Promise<void> {
  const signals = await (this.prisma as any).superEngulfingSignal.findMany({
    where: {
      strategyType: '3OB',
      lifecycleStatus: { in: ['PENDING', 'ACTIVE'] },
    },
  });

  if (signals.length === 0) return;

  const TFMS: Record<string, number> = {
    '1m': 60000,
    '5m': 300000,
    '15m': 900000,
    '1h': 3600000,
    '4h': 14400000,
    '1d': 86400000,
    '1w': 604800000,
  };

  const now = Date.now();
  let wins = 0;
  let failed = 0;

  for (const signal of signals) {
    try {
      const tfMs = TFMS[signal.timeframe] ?? TFMS['4h'];
      const detectedAt = new Date(signal.detectedAt).getTime();
      const candlesSince = Math.floor((now - detectedAt) / tfMs);

      // Not even 1 candle has closed yet — skip
      if (candlesSince < 1) continue;

      // Fetch last 7 candles (5 lifecycle candles + signal candle + 1 forming)
      const klines = await this.candlesService.getKlines(signal.symbol, signal.timeframe, 8);
      // Remove the forming (last) candle
      const closed = klines.slice(0, -1);
      if (closed.length < 2) continue;

      // Find candles that closed AFTER signal detection
      const postSignalCandles = closed.filter(
        (c: any) => c.openTime > detectedAt,
      );

      if (postSignalCandles.length === 0) continue;

      const entry = Number(signal.price);
      const lowestLow = Number(signal.metadata?.lowestlow ?? 0);
      const highestHigh = Number(signal.metadata?.highesthigh ?? 0);
      const isBuy = signal.signalType === 'BUY';

      let result: 'WIN' | 'FAILED' | null = null;

      for (const candle of postSignalCandles) {
        // INSTANT FAIL CHECK (wick-based)
        if (isBuy && candle.low <= lowestLow) {
          result = 'FAILED';
          break;
        }
        if (!isBuy && candle.high >= highestHigh) {
          result = 'FAILED';
          break;
        }

        // WIN CHECK (body close-based)
        if (isBuy && candle.close > entry) {
          result = 'WIN';
          break;
        }
        if (!isBuy && candle.close < entry) {
          result = 'WIN';
          break;
        }
      }

      // TIME FAIL: 5 candles passed with no result
      if (result === null && candlesSince >= 5) {
        result = 'FAILED';
      }

      // Not resolved yet
      if (result === null) continue;

      // Determine SignalResult and SignalStatus
      const signalResult = result === 'WIN' ? 'WIN' : 'LOSS';

      // Close the signal
      await (this.prisma as any).superEngulfingSignal.update({
        where: { id: signal.id },
        data: {
          lifecycleStatus: 'COMPLETED',
          status: 'CLOSED',
          result: signalResult,
          closedAt: new Date(),
          seclosereason: result,
        },
      });

      if (result === 'WIN') wins++;
      else failed++;
    } catch (err) {
      this.logger.error(`3OB lifecycle error for ${signal.id}: ${err}`);
    }
  }

  // Hard-delete 3OB signals COMPLETED for more than 24h
  try {
    await (this.prisma as any).superEngulfingSignal.deleteMany({
      where: {
        strategyType: '3OB',
        lifecycleStatus: 'COMPLETED',
        closedAt: { lt: new Date(Date.now() - 24 * 60 * 60 * 1000) },
      },
    });
  } catch (err) {
    this.logger.error(`3OB delete stale error: ${err}`);
  }

  if (wins + failed > 0) {
    this.logger.log(`3OB lifecycle: WIN=${wins}, FAILED=${failed}`);
  }
}
```


