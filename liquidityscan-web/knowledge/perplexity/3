lbR_major    = input.int(2,  minval = 0, title = 'Major — Right Lookback (lbR)', group = 'Major Divergence (High Quality)')
rangeL_major = input.int(5,  minval = 1, title = 'Major — Min Bars Between Pivots', group = 'Major Divergence (High Quality)')
rangeU_major = input.int(100, minval = 1, title = 'Major — Max Bars Between Pivots', group = 'Major Divergence (High Quality)')

// MINOR settings (faster, shorter divergences)
lbL_minor    = input.int(5,  minval = 1, title = 'Minor — Left Lookback  (lbL)', group = 'Minor Divergence (Early Signal)')
lbR_minor    = input.int(1,  minval = 0, title = 'Minor — Right Lookback (lbR)', group = 'Minor Divergence (Early Signal)')
rangeL_minor = input.int(3,  minval = 1, title = 'Minor — Min Bars Between Pivots', group = 'Minor Divergence (Early Signal)')
rangeU_minor = input.int(40, minval = 1, title = 'Minor — Max Bars Between Pivots', group = 'Minor Divergence (Early Signal)')
//}

// CALCULATIONS
osc   = ta.rsi(oscSrc, oscLen)
oscMA = ma(osc, maLengthInput, maTypeInput)

// DIVERGENCE FUNCTION — reusable for both passes
f_divergence(lbL, lbR, rangeLower, rangeUpper) =>
    _inRange(cond) =>
        bars = ta.barssince(cond == true)
        rangeLower <= bars and bars <= rangeUpper

    plFound = not na(ta.pivotlow(osc, lbL, lbR))
    phFound = not na(ta.pivothigh(osc, lbL, lbR))

    plFoundInRange = _inRange(plFound[1])
    phFoundInRange = _inRange(phFound[1])

    // Bullish pivot values
    osc_Curr_L   = osc[lbR]
    osc_Prev_L   = ta.valuewhen(plFound, osc[lbR], 1)
    price_Curr_L = low[lbR]
    price_Prev_L = ta.valuewhen(plFound, low[lbR], 1)
    bar_Curr_L   = bar_index - lbR
    bar_Prev_L   = ta.valuewhen(plFound, bar_index - lbR, 1)

    // Bearish pivot values
    osc_Curr_H   = osc[lbR]
    osc_Prev_H   = ta.valuewhen(phFound, osc[lbR], 1)
    price_Curr_H = high[lbR]
    price_Prev_H = ta.valuewhen(phFound, high[lbR], 1)
    bar_Curr_H   = bar_index - lbR
    bar_Prev_H   = ta.valuewhen(phFound, bar_index - lbR, 1)

    // Divergence structure
    regularBullStruct = osc_Curr_L > osc_Prev_L and price_Curr_L < price_Prev_L and plFoundInRange
    regularBearStruct = osc_Curr_H < osc_Prev_H and price_Curr_H > price_Prev_H and phFoundInRange

    startIsOversold   = osc_Prev_L < limitLower
    startIsOverbought = osc_Prev_H > limitUpper

    bullCond = plotBull and regularBullStruct and plFound and startIsOversold
    bearCond = plotBear and regularBearStruct and phFound and startIsOverbought

    [bullCond, bearCond,
     bar_Prev_L, osc_Prev_L, price_Prev_L, bar_Curr_L, osc_Curr_L, price_Curr_L,
     bar_Prev_H, osc_Prev_H, price_Prev_H, bar_Curr_H, osc_Curr_H, price_Curr_H,
     lbR]

// RUN BOTH PASSES
[bull_maj, bear_maj,
 bPL_maj, oPL_maj, pPL_maj, bCL_maj, oCL_maj, pCL_maj,
 bPH_maj, oPH_maj, pPH_maj, bCH_maj, oCH_maj, pCH_maj,
 lbR_maj_out] = f_divergence(lbL_major, lbR_major, rangeL_major, rangeU_major)

[bull_min, bear_min,
 bPL_min, oPL_min, pPL_min, bCL_min, oCL_min, pCL_min,
 bPH_min, oPH_min, pPH_min, bCH_min, oCH_min, pCH_min,
 lbR_min_out] = f_divergence(lbL_minor, lbR_minor, rangeL_minor, rangeU_minor)

// COLORS
// Major = solid/bright | Minor = transparent/lighter
majorBullColor = color.new(color.green, 0)
majorBearColor = color.new(color.red, 0)
minorBullColor = color.new(color.green, 55)
minorBearColor = color.new(color.red, 55)

// PLOTTING
oscUB = hline(limitUpper, 'Upper Bound', color = color.new(#787B86, 50))
oscMB = hline(50, 'Middle Bound', color = color.new(#787B86, 50))
oscLB = hline(limitLower, 'Lower Bound', color = color.new(#787B86, 50))
fill(oscUB, oscLB, color = color.rgb(126, 87, 194, 90))

oscRSI = plot(osc, title = 'RSI', linewidth = 1, color = color.rgb(209, 212, 220))
plot(oscMA, 'Moving Average', color = color.new(color.yellow, 20))

// Major dots
plot(bull_maj ? oCL_maj : na, offset = -lbR_major, title = 'Major Bull', linewidth = 4, color = majorBullColor, style = plot.style_circles)
plot(bear_maj ? oCH_maj : na, offset = -lbR_major, title = 'Major Bear', linewidth = 4, color = majorBearColor, style = plot.style_circles)

// Minor dots
plot(bull_min ? oCL_min : na, offset = -lbR_minor, title = 'Minor Bull', linewidth = 3, color = minorBullColor, style = plot.style_circles)
plot(bear_min ? oCH_min : na, offset = -lbR_minor, title = 'Minor Bear', linewidth = 3, color = minorBearColor, style = plot.style_circles)

// Major lines
if bull_maj
    line.new(bPL_maj, oPL_maj, bCL_maj, oCL_maj, color = majorBullColor, width = 2)
    line.new(bPL_maj, pPL_maj, bCL_maj, pCL_maj, color = majorBullColor, width = 2, force_overlay = true)
if bear_maj
    line.new(bPH_maj, oPH_maj, bCH_maj, oCH_maj, color = majorBearColor, width = 2)
    line.new(bPH_maj, pPH_maj, bCH_maj, pCH_maj, color = majorBearColor, width = 2, force_overlay = true)

// Minor lines
if bull_min
    line.new(bPL_min, oPL_min, bCL_min, oCL_min, color = minorBullColor, width = 1, style = line.style_dashed)
    line.new(bPL_min, pPL_min, bCL_min, pCL_min, color = minorBullColor, width = 1, style = line.style_dashed, force_overlay = true)
if bear_min
    line.new(bPH_min, oPH_min, bCH_min, oCH_min, color = minorBearColor, width = 1, style = line.style_dashed)
    line.new(bPH_min, pPH_min, bCH_min, pCH_min, color = minorBearColor, width = 1, style = line.style_dashed, force_overlay = true)

// Gradients
midLinePlot = plot(50, color = na, editable = false, display = display.none)
fill(oscRSI, midLinePlot, 100, 70, top_color = color.new(color.red, 0),    bottom_color = color.new(color.red, 100),    title = 'Overbought Gradient')
fill(oscRSI, midLinePlot, 30,  0,  top_color = color.new(color.green, 100), bottom_color = color.new(color.green, 0),   title = 'Oversold Gradient')

// ALERTS
alertcondition(bull_maj, title = 'Major Bullish Divergence', message = 'Major Bullish Divergence')
alertcondition(bear_maj, title = 'Major Bearish Divergence', message = 'Major Bearish Divergence')
alertcondition(bull_min, title = 'Minor Bullish Divergence', message = 'Minor Bullish Divergence')
alertcondition(bear_min, title = 'Minor Bearish Divergence', message = 'Minor Bearish Divergence')
