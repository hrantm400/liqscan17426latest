    lbL: 10, lbR: 2, rangeLower: 15, rangeUpper: 80,
    limitUpper: 70, limitLower: 30,
  },
  {
    enabled: false, label: 'Pass4',
    lbL: 20, lbR: 3, rangeLower: 30, rangeUpper: 150,
    limitUpper: 70, limitLower: 30,
  },
];

// ─── RSI CALCULATION (Wilder's RMA — matches TradingView) ────────────────────

export function calculateRSI(closes: number[], length = 14): number[] {
  const rsi: number[] = new Array(closes.length).fill(NaN);
  if (closes.length < length + 1) return rsi;

  const changes = closes.slice(1).map((c, i) => c - closes[i]);
  let avgGain = changes.slice(0, length).filter(c => c > 0).reduce((a, b) => a + b, 0) / length;
  let avgLoss = changes.slice(0, length).filter(c => c < 0).reduce((a, b) => a + Math.abs(b), 0) / length;

  rsi[length] = 100 - 100 / (1 + (avgLoss === 0 ? Infinity : avgGain / avgLoss));

  for (let i = length; i < changes.length; i++) {
    const gain = Math.max(changes[i], 0);
    const loss = Math.abs(Math.min(changes[i], 0));
    avgGain = (avgGain * (length - 1) + gain) / length;
    avgLoss = (avgLoss * (length - 1) + loss) / length;
    rsi[i + 1] = 100 - 100 / (1 + (avgLoss === 0 ? Infinity : avgGain / avgLoss));
  }

  return rsi;
}

// ─── PIVOT DETECTION ─────────────────────────────────────────────────────────

export function findPivotLows(values: number[], lbL: number, lbR: number): PivotPoint[] {
  const pivots: PivotPoint[] = [];
  for (let i = lbL; i < values.length - lbR; i++) {
    if (isNaN(values[i])) continue;
    const leftOk  = values.slice(i - lbL, i).every(v => v >= values[i]);
    const rightOk = values.slice(i + 1, i + lbR + 1).every(v => v >= values[i]);
    if (leftOk && rightOk) pivots.push({ index: i, value: values[i] });
  }
  return pivots;
}

export function findPivotHighs(values: number[], lbL: number, lbR: number): PivotPoint[] {
  const pivots: PivotPoint[] = [];
  for (let i = lbL; i < values.length - lbR; i++) {
    if (isNaN(values[i])) continue;
    const leftOk  = values.slice(i - lbL, i).every(v => v <= values[i]);
    const rightOk = values.slice(i + 1, i + lbR + 1).every(v => v <= values[i]);
    if (leftOk && rightOk) pivots.push({ index: i, value: values[i] });
  }
  return pivots;
}

// ─── SINGLE PASS DETECTION ───────────────────────────────────────────────────

function detectSinglePass(candles: CandleData[], pass: PassConfig): RsiDivergenceSignal[] {
  const { lbL, lbR, rangeLower, rangeUpper, limitUpper, limitLower, label } = pass;
  const closes = candles.map(c => c.close);
  const highs  = candles.map(c => c.high);
  const lows   = candles.map(c => c.low);
  const rsi    = calculateRSI(closes, 14);
  const signals: RsiDivergenceSignal[] = [];

  const latestAllowedIndex = candles.length - 1 - lbR;
  const pivotLows  = findPivotLows(rsi,  lbL, lbR);
  const pivotHighs = findPivotHighs(rsi, lbL, lbR);

  // ── BULLISH ──────────────────────────────────────────────────────────────
  for (let i = 1; i < pivotLows.length; i++) {
    const prev = pivotLows[i - 1];
    const curr = pivotLows[i];

    if (curr.index !== latestAllowedIndex) continue; // only most recent pivot
    const barsBetween = curr.index - prev.index;
    if (barsBetween < rangeLower || barsBetween > rangeUpper) continue;
    if (prev.value >= limitLower) continue;           // P1 must be oversold

    const rsiHigherLow  = curr.value > prev.value;
    const priceLowerLow = lows[curr.index] < lows[prev.index];
    if (!rsiHigherLow || !priceLowerLow) continue;

    // Structure filter — price must have rallied above P1 between the two pivots
    const highBetween = Math.max(...highs.slice(prev.index, curr.index + 1));
    if (highBetween <= lows[prev.index]) continue;

    signals.push({
      signalType:     'BUY',
      divergenceType: 'bullish_divergence',
      passLabel:      label,
      price:          lows[curr.index],
      pivotTime:      candles[curr.index].openTime,
      pivotPrice:     lows[curr.index],
      pivotRsi:       curr.value,
      prevPivotTime:  candles[prev.index].openTime,
      prevPivotPrice: lows[prev.index],
      prevPivotRsi:   prev.value,
    });
  }

  // ── BEARISH ──────────────────────────────────────────────────────────────
  for (let i = 1; i < pivotHighs.length; i++) {
    const prev = pivotHighs[i - 1];
    const curr = pivotHighs[i];

    if (curr.index !== latestAllowedIndex) continue;
    const barsBetween = curr.index - prev.index;
    if (barsBetween < rangeLower || barsBetween > rangeUpper) continue;
    if (prev.value <= limitUpper) continue;           // P1 must be overbought

    const rsiLowerHigh    = curr.value < prev.value;
    const priceHigherHigh = highs[curr.index] > highs[prev.index];
    if (!rsiLowerHigh || !priceHigherHigh) continue;

    // Structure filter — price must have dropped below P1 between the two pivots
    const lowBetween = Math.min(...lows.slice(prev.index, curr.index + 1));
    if (lowBetween >= highs[prev.index]) continue;

    signals.push({
      signalType:     'SELL',
      divergenceType: 'bearish_divergence',
      passLabel:      label,
      price:          highs[curr.index],
      pivotTime:      candles[curr.index].openTime,
      pivotPrice:     highs[curr.index],
      pivotRsi:       curr.value,
      prevPivotTime:  candles[prev.index].openTime,
      prevPivotPrice: highs[prev.index],
      prevPivotRsi:   prev.value,
    });
  }

  return signals;
}

// ─── MAIN EXPORT — runs all passes ───────────────────────────────────────────

export function detectRSIDivergence(
  candles: CandleData[],
  passes: PassConfig[] = DEFAULT_PASSES,
): RsiDivergenceSignal[] {
  const all: RsiDivergenceSignal[] = [];
  for (const pass of passes) {
    if (!pass.enabled) continue;
    all.push(...detectSinglePass(candles, pass));
  }
  return all;
}
```


